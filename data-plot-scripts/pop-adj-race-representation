# =====================================================
# 10. REAL POPULATION ADJUSTMENT
# =====================================================
race_to_prop = {"white":"white_prop", "black":"black_prop", "other":"other_prop"}
records = []

for ideology in ["negative","positive"]:
    sub = crime_rows[crime_rows["ideology_label"]==ideology]
    for role, col in [("perp","perp_race_norm"),("victim","victim_race_norm")]:
        role_df = sub[sub[col].notna()]
        for race in ["white","black","other"]:
            observed = (role_df[col]==race).sum()
            expected = role_df[race_to_prop[race]].sum()
            ratio = observed/expected if expected>0 else None
            records.append({
                "ideology":ideology,
                "role":role,
                "race":race,
                "observed":observed,
                "expected":expected,
                "representation_ratio":ratio
            })

adj_df = pd.DataFrame(records)

# =====================================================
# 11. ADD "ALL" IDEOLOGY
# =====================================================
all_records=[]
for role in adj_df["role"].unique():
    for race in ["white","black","other"]:
        sub=adj_df[(adj_df["role"]==role)&(adj_df["race"]==race)]
        obs=sub["observed"].sum()
        exp=sub["expected"].sum()
        all_records.append({
            "ideology":"all",
            "role":role,
            "race":race,
            "observed":obs,
            "expected":exp,
            "representation_ratio":obs/exp if exp>0 else None
        })
adj_df = pd.concat([adj_df, pd.DataFrame(all_records)], ignore_index=True)

# =====================================================
# 12. LOG-SCALE POISSON CONFIDENCE INTERVALS
# =====================================================
adj_df["ci_lower"] = None
adj_df["ci_upper"] = None

for i, row in adj_df.iterrows():
    O = row["observed"]
    E = row["expected"]
    if O>0 and E>0:
        ratio = O/E
        se_log = 1/np.sqrt(O)
        lower = np.exp(np.log(ratio)-1.96*se_log)
        upper = np.exp(np.log(ratio)+1.96*se_log)
        adj_df.at[i,"ci_lower"]=lower
        adj_df.at[i,"ci_upper"]=upper
    else:
        adj_df.at[i,"ci_lower"]=0
        adj_df.at[i,"ci_upper"]=0

# =====================================================
# 13. PLOT FUNCTION WITH CORRECT ERROR BAR MAPPING
# =====================================================
def plot_population_adjusted(df, ideology_label):
    subset = df[df["ideology"]==ideology_label].reset_index(drop=True)
    plt.figure(figsize=(10,6))

    ax = sns.barplot(
        data=subset,
        x="race",
        y="representation_ratio",
        hue="role",
        errorbar=None
    )

    # Correctly map error bars to bars
    for i, (race, role) in enumerate(subset[["race","role"]].itertuples(index=False)):
        bar = ax.patches[i]
        height = bar.get_height()
        x = bar.get_x() + bar.get_width()/2
        lower = subset.loc[(subset["race"]==race) & (subset["role"]==role), "ci_lower"].values[0]
        upper = subset.loc[(subset["race"]==race) & (subset["role"]==role), "ci_upper"].values[0]
        yerr_lower = max(0, height - lower)
        yerr_upper = max(0, upper - height)

        ax.errorbar(
            x=x,
            y=height,
            yerr=[[yerr_lower],[yerr_upper]],
            fmt='none',
            color='black',
            capsize=6,
            linewidth=1.5
        )

    plt.axhline(1, linestyle="--", color="gray")
    plt.title(f"Population-Adjusted Race Representation ({ideology_label})")
    plt.ylabel("Observed / Expected")
    plt.xlabel("Race")
    plt.tight_layout()
    plt.show()

