import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from urllib.parse import urlparse
from collections import Counter


# load files
news   = pd.read_csv("joint_news_sources(in) (1).csv")
people = pd.read_csv("people_info_cleaned_latest (3).csv")


# normalize domains for merging
# news file has full URLs; people file needs domain extracted via urlparse
news["url_norm"] = news["URL"].str.strip().str.lower()

def extract_domain(url):
    try:
        parsed = urlparse(url.strip().lower())
        domain = parsed.netloc
        if domain.startswith("www."):
            domain = domain[4:]
        return domain
    except:
        return None

people["url_norm"] = people["url"].apply(extract_domain)


# merge people with news metadata, keep only rows with an ideology score
merged = people.merge(
    news[["url_norm", "ideology", "state"]],
    on="url_norm",
    how="left"
)
merged = merged[merged["ideology"].notna()].copy()


# bin continuous ideology scores into directional labels
# zero is excluded (treated as no lean)
def categorize_ideology(score):
    if score < 0:
        return "negative"
    elif score > 0:
        return "positive"
    return None

merged["ideology_label"] = merged["ideology"].apply(categorize_ideology)
merged = merged[merged["ideology_label"].notna()]


# helpers for aggregating llm labels across gpt / llama / qwen
def any_label(values):
    # return True if at least one non-null, non-empty, non-"not_provided" value exists
    return any(
        pd.notna(v)
        and str(v).strip() != ""
        and str(v).strip().lower() != "not_provided"
        for v in values
    )

def majority_vote(values):
    # return the most common valid value; None if no majority or all values are missing
    clean = [
        str(v).strip().lower()
        for v in values
        if pd.notna(v)
        and str(v).strip() != ""
        and str(v).strip().lower() != "not_provided"
    ]
    if not clean:
        return None
    counts = Counter(clean)
    top = counts.most_common()
    # tied top values → no majority
    if len(top) > 1 and top[0][1] == top[1][1]:
        return None
    return top[0][0]


# keep only rows where at least one llm assigned a crime label
merged["crime_any"] = merged.apply(
    lambda r: any_label([r.get("gpt_crime"), r.get("llama_crime"), r.get("qwen_crime")]),
    axis=1
)
crime_rows = merged[merged["crime_any"]].copy()
print("Rows with ANY crime label:", len(crime_rows))


# soft majority race labels — require at least 2 of 3 llms to agree
crime_rows["perp_race_soft"] = crime_rows.apply(
    lambda r: majority_vote([r.get("gpt_perp_race"), r.get("llama_perp_race"), r.get("qwen_perp_race")]),
    axis=1
)
crime_rows["victim_race_soft"] = crime_rows.apply(
    lambda r: majority_vote([r.get("gpt_victim_race"), r.get("llama_victim_race"), r.get("qwen_victim_race")]),
    axis=1
)


# collapse race labels to white / black / other; treat unknown/missing as None
def normalize_race(race):
    if pd.isna(race):
        return None
    race = str(race).strip().lower()
    if race in ["", "not_provided", "unknown"]:
        return None
    if race == "white":
        return "white"
    if race == "black":
        return "black"
    return "other"

crime_rows["perp_race_norm"]   = crime_rows["perp_race_soft"].apply(normalize_race)
crime_rows["victim_race_norm"] = crime_rows["victim_race_soft"].apply(normalize_race)

# drop rows where neither role has a valid race label
crime_rows = crime_rows[
    crime_rows["perp_race_norm"].notna() | crime_rows["victim_race_norm"].notna()
]


