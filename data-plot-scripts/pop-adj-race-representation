crime_rows = crime_rows[crime_rows["white_prop"].notna()]


# compute observed vs expected counts per ideology × role × race.
# expected = sum of each article's state-level population share for that race,
# which accounts for the geographic mix of sources rather than using a single national figure.
race_to_prop = {"white": "white_prop", "black": "black_prop", "other": "other_prop"}
records = []

for ideology in ["negative", "positive"]:
    sub = crime_rows[crime_rows["ideology_label"] == ideology]
    for role, col in [("perp", "perp_race_norm"), ("victim", "victim_race_norm")]:
        role_df = sub[sub[col].notna()]
        for race in ["white", "black", "other"]:
            observed = (role_df[col] == race).sum()
            expected = role_df[race_to_prop[race]].sum()
            records.append({
                "ideology":            ideology,
                "role":                role,
                "race":                race,
                "observed":            observed,
                "expected":            expected,
                "representation_ratio": observed / expected if expected > 0 else None,
            })

adj_df = pd.DataFrame(records)


# add an "all" ideology group by summing observed and expected across ideologies
all_records = []
for role in adj_df["role"].unique():
    for race in ["white", "black", "other"]:
        sub = adj_df[(adj_df["role"] == role) & (adj_df["race"] == race)]
        obs = sub["observed"].sum()
        exp = sub["expected"].sum()
        all_records.append({
            "ideology":            "all",
            "role":                role,
            "race":                race,
            "observed":            obs,
            "expected":            exp,
            "representation_ratio": obs / exp if exp > 0 else None,
        })

adj_df = pd.concat([adj_df, pd.DataFrame(all_records)], ignore_index=True)


# log-scale poisson confidence intervals around the representation ratio.
# se(log ratio) = 1/sqrt(O), so CI = ratio * exp(±1.96/sqrt(O))
adj_df["ci_lower"] = None
adj_df["ci_upper"] = None

for i, row in adj_df.iterrows():
    O, E = row["observed"], row["expected"]
    if O > 0 and E > 0:
        ratio   = O / E
        se_log  = 1 / np.sqrt(O)
        adj_df.at[i, "ci_lower"] = np.exp(np.log(ratio) - 1.96 * se_log)
        adj_df.at[i, "ci_upper"] = np.exp(np.log(ratio) + 1.96 * se_log)
    else:
        adj_df.at[i, "ci_lower"] = 0
        adj_df.at[i, "ci_upper"] = 0


def plot_population_adjusted(df, ideology_label):
    # plot observed/expected representation ratios for perp vs victim by race.
    # error bars are asymmetric poisson CIs mapped manually to each bar patch,
    # since seaborn's errorbar param doesn't support pre-computed intervals.
    subset = df[df["ideology"] == ideology_label].reset_index(drop=True)

    plt.figure(figsize=(10, 6))
    ax = sns.barplot(
        data=subset,
        x="race",
        y="representation_ratio",
        hue="role",
        errorbar=None,
    )

    for i, (race, role) in enumerate(subset[["race", "role"]].itertuples(index=False)):
        bar    = ax.patches[i]
        height = bar.get_height()
        x      = bar.get_x() + bar.get_width() / 2

        row        = subset[(subset["race"] == race) & (subset["role"] == role)]
        yerr_lower = max(0, height - row["ci_lower"].values[0])
        yerr_upper = max(0, row["ci_upper"].values[0] - height)

        ax.errorbar(
            x=x, y=height,
            yerr=[[yerr_lower], [yerr_upper]],
            fmt="none", color="black", capsize=6, linewidth=1.5,
        )

    plt.axhline(1, linestyle="--", color="gray")
    plt.title(f"Population-Adjusted Race Representation ({ideology_label})")
    plt.ylabel("Observed / Expected")
    plt.xlabel("Race")
    plt.tight_layout()
    plt.show()


# generate one plot per ideology panel
for ideology in ["negative", "positive", "all"]:
    plot_population_adjusted(adj_df, ideology)
