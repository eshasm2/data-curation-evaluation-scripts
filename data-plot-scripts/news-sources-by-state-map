import pandas as pd
import matplotlib.pyplot as plt
import numpy as np


# load files
master  = pd.read_csv("joint_news_sources(in) (1).csv")
sources = pd.read_csv("combined_outputs.csv")


# extract bare domain from URL for merging
# strips protocol (http/https) and www. prefix, then takes everything before the first slash
def extract_domain(url_series):
    return (
        url_series
        .str.lower()
        .str.replace(r'^https?://', '', regex=True)
        .str.replace(r'^www\.', '', regex=True)
        .str.split('/')
        .str[0]
    )

master['domain']  = extract_domain(master['URL'])
sources['domain'] = extract_domain(sources['url'])


# merge ideology scores from master into the article-level sources data
# left join keeps all articles; rows without a matching domain get NaN ideology
merged = sources.merge(
    master[['domain', 'ideology']],
    on='domain',
    how='left'
)
merged = merged.dropna(subset=['ideology'])


# bin continuous ideology scores into three directional categories
bins   = [-1, -0.1, 0.1, 1]
labels = ['Left-leaning (< -0.1)', 'Center (-0.1 to 0.1)', 'Right-leaning (> 0.1)']

merged['category'] = pd.cut(merged['ideology'], bins=bins, labels=labels)


# histogram of ideology scores across all sources
plt.figure(figsize=(10, 6))
plt.hist(merged['ideology'], bins=np.linspace(-1, 1, 20), edgecolor='black')
plt.axvline(0, linestyle='--')
plt.title("Distribution of Ideology Scores Across US Newspaper Sources")
plt.xlabel("Political Leaning Score")
plt.ylabel("Number of Articles")
plt.tight_layout()
plt.show()


# summary statistics
counts       = merged['category'].value_counts().reindex(labels).fillna(0).astype(int)
mean_score   = round(merged['ideology'].mean(), 3)
median_score = round(merged['ideology'].median(), 3)

print("\nCounts by Category:")
print(counts)
print(f"\nMean Ideology Score:   {mean_score}")
print(f"Median Ideology Score: {median_score}")
print(f"\nTotal Articles with Ideology: {len(merged)}")
