import pandas as pd
import numpy as np
import re
from itertools import combinations
from collections import Counter
from sklearn.metrics import cohen_kappa_score


# load inputs
# llm_raw   = LLM annotations (GPT, LLaMA, Qwen) at the person level
# mapping   = links article UIDs (e.g. "ART0042") to numeric IDs

llm_raw   = pd.read_csv("people_info_cleaned_latest (3).csv")
human_raw = pd.read_csv("data_for_qualtrics.csv", header=0, skiprows=[1])
mapping   = pd.read_csv("strat_sample_for_el_with_article_uid.csv")


# extract numeric article id from mapping
# the mapping file uses UIDs like "ART0042" — we pull out just the number (42)
# so we can match on it across all three files

mapping['art_num'] = mapping['article_uid'].str.extract(r'ART(\d+)').astype(int)


# collapse llm data to one row per article
# the llm file has one row per person mentioned in an article,
# but we need one row per article for comparison with human coders.
# we take the first row per article since article-level labels should be consistent

llm_raw['art_num'] = llm_raw['article_id'].astype(int)

llm_cols = [
    'gpt_crime_present', 'gpt_violent_crime', 'gpt_crime',
    'gpt_perp_race', 'gpt_perp_gender', 'gpt_victim_race', 'gpt_victim_gender',
    'llama_crime_present', 'llama_violent_crime', 'llama_crime',
    'llama_perp_race', 'llama_perp_gender', 'llama_victim_race', 'llama_victim_gender',
    'qwen_crime_present', 'qwen_violent_crime', 'qwen_crime',
    'qwen_perp_race', 'qwen_perp_gender', 'qwen_victim_race', 'qwen_victim_gender',
]

llm = llm_raw.groupby('art_num')[llm_cols].first().reset_index()


# reshape human coder data to long format
# qualtrics exports one row per rater with columns.

# drop qualtrics header/preview rows
art_q1 = 'ART0001_Q1_CRIME_COMMITTED'
human_data = human_raw[~human_raw[art_q1].astype(str).str.startswith('{')].copy()
human_data = human_data[human_data[art_q1].notna()].reset_index(drop=True)
human_data['rater'] = ['Eleanor', 'Sarah'][:len(human_data)]

art_cols = [c for c in human_data.columns if re.match(r'ART\d{4}_Q', c)]

# reshape from wide to long format so each row is one answer
# before: one row per rater, many columns like ART0001_Q1, ART0001_Q2, ART0002_Q1...
# after:  one row per (rater, column), with the column name and value as separate fields
long_answers = human_data[['rater'] + art_cols].melt(id_vars=['rater'], var_name='col', value_name='value')

# pull the article number and question name out of the column name
# e.g. "ART0001_Q1_CRIME_COMMITTED" → art_num=1, question="Q1_CRIME_COMMITTED"
long_answers['art_num']  = long_answers['col'].str.extract(r'ART(\d+)').astype(int)
long_answers['question'] = long_answers['col'].str.replace(r'ART\d+_', '', regex=True)

# pivot so each row = one rater x one article, and each question becomes its own column
# this is the format we need to compare raters side by side
human_long = long_answers.pivot_table(
    index=['rater', 'art_num'], columns='question', values='value', aggfunc='first'
).reset_index()
human_long.columns.name = None


# normalize labels across raters and llms
# different raters/llms may use different capitalization or phrasing.
# we standardize to lowercase and collapse rare race categories into "other".
# ambiguous values (unknown, multiple, not provided) become NaN.

race_collapse = {
    'hispanic': 'other', 'asian': 'other', 'middle eastern': 'other',
    'pacific islander': 'other', 'native american': 'other', 'native': 'other',
    'no name provided': np.nan, 'multiple': np.nan, 'unknown': np.nan,
    'not_provided': np.nan, 'not provided': np.nan,
}

gender_collapse = {
    'no name provided': np.nan, 'multiple': np.nan,
    'not_provided': np.nan, 'not provided': np.nan, 'nonbinary/other': np.nan,
}

def normalize(val, collapse_dict=None):
    "lowercase and strip a value"
    if pd.isna(val):
        return np.nan
    v = str(val).strip().lower()
    if v in ('', 'nan', 'none'):
        return np.nan
    if collapse_dict and v in collapse_dict:
        return collapse_dict[v]
    return v

def norm_yn(val):
    "standardize yes/no fields"
    v = normalize(val)
    if v in ('yes', 'true', '1'):
        return 'yes'
    if v in ('no', 'false', '0'):
        return 'no'
    return np.nan

def norm_race(val):
    return normalize(val, race_collapse)

def norm_gender(val):
    return normalize(val, gender_collapse)

# normalize llm yes/no columns
for c in ['gpt_crime_present', 'gpt_violent_crime', 'llama_crime_present',
          'llama_violent_crime', 'qwen_crime_present', 'qwen_violent_crime']:
    llm[c] = llm[c].apply(norm_yn)

# normalize llm race columns
for c in ['gpt_perp_race', 'gpt_victim_race', 'llama_perp_race',
          'llama_victim_race', 'qwen_perp_race', 'qwen_victim_race']:
    llm[c] = llm[c].apply(norm_race)

# normalize llm gender columns
for c in ['gpt_perp_gender', 'gpt_victim_gender', 'llama_perp_gender',
          'llama_victim_gender', 'qwen_perp_gender', 'qwen_victim_gender']:
    llm[c] = llm[c].apply(norm_gender)

# normalize llm crime label columns
for c in ['gpt_crime', 'llama_crime', 'qwen_crime']:
    llm[c] = llm[c].apply(normalize)

# helper to find the right qualtrics column by partial name match
def find_col(df, pattern):
    matches = [c for c in df.columns if pattern.lower() in c.lower()]
    return matches[0] if matches else None

# map our variable names to the actual qualtrics column names
q_map = {
    'crime_present': find_col(human_long, 'Q1_CRIME_COMMITTED'),
    'violent_crime': find_col(human_long, 'Q2_VIOLENT'),
    'perp_race':     find_col(human_long, 'Q4_PERP_RACE'),
    'perp_gender':   find_col(human_long, 'Q6_PERP_GENDER'),
    'victim_race':   find_col(human_long, 'Q9_VICTIM_RACE'),
    'victim_gender': find_col(human_long, 'Q11_VICTIM_GENDER'),
    'crime_label':   find_col(human_long, 'Q13_CRIME_LABEL'),
}

# normalize human coder responses using the same rules as the llm columns
if q_map['crime_present']: human_long['crime_present'] = human_long[q_map['crime_present']].apply(norm_yn)
if q_map['violent_crime']: human_long['violent_crime'] = human_long[q_map['violent_crime']].apply(norm_yn)
if q_map['perp_race']:     human_long['perp_race']     = human_long[q_map['perp_race']].apply(norm_race)
if q_map['perp_gender']:   human_long['perp_gender']   = human_long[q_map['perp_gender']].apply(norm_gender)
if q_map['victim_race']:   human_long['victim_race']   = human_long[q_map['victim_race']].apply(norm_race)
if q_map['victim_gender']: human_long['victim_gender'] = human_long[q_map['victim_gender']].apply(norm_gender)
if q_map['crime_label']:   human_long['crime_label']   = human_long[q_map['crime_label']].apply(normalize)


# merge human and llm data
# split Eleanor and Sarah into separate dataframes, then merge both
# with the llm data on article number

norm_vars = ['crime_present', 'violent_crime', 'perp_race', 'perp_gender',
             'victim_race', 'victim_gender', 'crime_label']

eleanor = human_long[human_long['rater'] == 'Eleanor'][['art_num'] + norm_vars].copy()
eleanor.columns = ['art_num'] + [f'eleanor_{c}' for c in norm_vars]

sarah = human_long[human_long['rater'] == 'Sarah'][['art_num'] + norm_vars].copy()
sarah.columns = ['art_num'] + [f'sarah_{c}' for c in norm_vars]

merged = llm.merge(eleanor, on='art_num', how='inner').merge(sarah, on='art_num', how='inner')
print(f"Final merged articles: {len(merged)}")


# agreement metrics
#
# binary variables (crime_present, violent_crime) → cohen's kappa
#   kappa corrects for chance agreement between two raters
# nominal variables (race, gender, crime_label)   → krippendorff's alpha
#   alpha handles multiple categories and missing data gracefully

binary_vars  = {'crime_present', 'violent_crime'}
nominal_vars = {'perp_race', 'perp_gender', 'victim_race', 'victim_gender', 'crime_label'}

def cohens_kappa(s1, s2):
    # cohen's kappa for two raters on a binary variable.
    # only uses rows where both raters gave a non-null answer.
    #   1.0  = perfect agreement
    #   0.0  = agreement no better than chance
    #  <0.0  = systematic disagreement
    # returns (kappa, n_valid_pairs).
    mask = s1.notna() & s2.notna()
    n = mask.sum()
    if n < 2:
        return np.nan, n
    try:
        kappa = cohen_kappa_score(s1[mask], s2[mask])
    except Exception:
        # can fail if only one unique label is present in the subset
        kappa = np.nan
    return round(kappa, 3), n


def kripp_alpha(df):

    # calculates Krippendorff's Alpha for nominal data across any number of raters.

    # alpha measures inter-rater reliability:
    #   1.0  = perfect agreement
    #   0.0  = agreement no better than chance
    #  <0.0  = systematic disagreement

    # we use the nominal metric (disagreement = 1 if values differ, 0 if same).
    # rows where fewer than 2 raters gave a non-null answer are skipped.

    # the formula is: alpha = 1 - (Do / De)
    #   Do = observed disagreement (proportion of differing pairs)
    #   De = expected disagreement under chance (based on overall value distribution)

    data = df.values.astype(object)
    coinc = {}  # coincidence matrix: counts how often each pair of values co-occur
    n_c = 0     # total number of value pairs seen

    for row in data:
        # get the non-null values for this article
        valid = [str(v) for v in row if v is not None and not (isinstance(v, float) and np.isnan(v))]
        if len(valid) < 2:
            continue
        # count all ordered pairs of values in this row
        for v1, v2 in combinations(valid, 2):
            for k in [(v1, v2), (v2, v1)]:
                coinc[k] = coinc.get(k, 0) + 1
                n_c += 1

    if n_c == 0:
        return np.nan

    # observed disagreement: proportion of pairs where values differ
    Do = sum(v for (k1, k2), v in coinc.items() if k1 != k2) / n_c

    # expected disagreement: based on marginal distribution of each value
    vc = {}
    for (k1, k2), cnt in coinc.items():
        vc[k1] = vc.get(k1, 0) + cnt
    tot = sum(vc.values())
    De = 1 - sum((c / tot) ** 2 for c in vc.values())

    if De == 0:
        return np.nan
    return round(1 - Do / De, 3)


# maps each variable to the column names for each rater
variables = {
    'crime_present': {'eleanor': 'eleanor_crime_present', 'sarah': 'sarah_crime_present',
                      'gpt': 'gpt_crime_present', 'llama': 'llama_crime_present', 'qwen': 'qwen_crime_present'},
    'violent_crime': {'eleanor': 'eleanor_violent_crime', 'sarah': 'sarah_violent_crime',
                      'gpt': 'gpt_violent_crime', 'llama': 'llama_violent_crime', 'qwen': 'qwen_violent_crime'},
    'crime_label':   {'eleanor': 'eleanor_crime_label', 'sarah': 'sarah_crime_label',
                      'gpt': 'gpt_crime', 'llama': 'llama_crime', 'qwen': 'qwen_crime'},
    'perp_race':     {'eleanor': 'eleanor_perp_race', 'sarah': 'sarah_perp_race',
                      'gpt': 'gpt_perp_race', 'llama': 'llama_perp_race', 'qwen': 'qwen_perp_race'},
    'perp_gender':   {'eleanor': 'eleanor_perp_gender', 'sarah': 'sarah_perp_gender',
                      'gpt': 'gpt_perp_gender', 'llama': 'llama_perp_gender', 'qwen': 'qwen_perp_gender'},
    'victim_race':   {'eleanor': 'eleanor_victim_race', 'sarah': 'sarah_victim_race',
                      'gpt': 'gpt_victim_race', 'llama': 'llama_victim_race', 'qwen': 'qwen_victim_race'},
    'victim_gender': {'eleanor': 'eleanor_victim_gender', 'sarah': 'sarah_victim_gender',
                      'gpt': 'gpt_victim_gender', 'llama': 'llama_victim_gender', 'qwen': 'qwen_victim_gender'},
}

raters = ['eleanor', 'sarah', 'gpt', 'llama', 'qwen']

# compute pairwise agreement and krippendorff's alpha for each variable.
# binary variables use cohen's kappa for pairwise; nominal use krippendorff's alpha.
# alpha is also computed across all raters and for human coders only as a summary.
results = []
for var, cols in variables.items():
    # only use raters whose column actually exists in the merged dataframe
    valid_cols = {}
    for r, c in cols.items():
        if c in merged.columns:
            valid_cols[r] = c

    # pairwise agreement for every rater combination
    # binary → cohen's kappa, nominal → krippendorff's alpha
    for r1, r2 in combinations(raters, 2):
        if r1 not in valid_cols or r2 not in valid_cols:
            continue
        if var in binary_vars:
            val, n = cohens_kappa(merged[valid_cols[r1]], merged[valid_cols[r2]])
            results.append({'variable': var, 'comparison': f'{r1}_vs_{r2}',
                            'metric': 'cohens_kappa', 'value': val, 'n': n})
        else:
            val = kripp_alpha(merged[[valid_cols[r1], valid_cols[r2]]])
            n = merged[[valid_cols[r1], valid_cols[r2]]].notna().all(axis=1).sum()
            results.append({'variable': var, 'comparison': f'{r1}_vs_{r2}',
                            'metric': 'krippendorff_alpha', 'value': val, 'n': n})

    # krippendorff's alpha across all available raters
    avail = [r for r in raters if r in valid_cols]
    if len(avail) >= 2:
        results.append({'variable': var, 'comparison': 'all_5_raters',
                        'metric': 'krippendorff_alpha',
                        'value': kripp_alpha(merged[[valid_cols[r] for r in avail]]),
                        'n': len(merged)})

    # krippendorff's alpha for human coders only
    if 'eleanor' in valid_cols and 'sarah' in valid_cols:
        results.append({'variable': var, 'comparison': 'human_only',
                        'metric': 'krippendorff_alpha',
                        'value': kripp_alpha(merged[[valid_cols['eleanor'], valid_cols['sarah']]]),
                        'n': len(merged)})

res = pd.DataFrame(results)

# inter-rater reliability — sarah vs eleanor only
irr = res[res['comparison'] == 'eleanor_vs_sarah'][['variable', 'metric', 'value', 'n']]
print("\n Inter-Rater Reliability: Sarah vs Eleanor ")
print(irr.to_string(index=False))

# llm majority vote
# create a majority vote label for each variable using the three llms.
# if at least 2 of the 3 llms agree, that value wins.
# if all three disagree, we treat it as missing (NaN).

def majority_vote(vals):
    # return the value that appears more than once; NaN if no majority.
    clean = [v for v in vals if pd.notna(v)]
    if not clean:
        return np.nan
    counts = Counter(clean)
    top_val, top_count = counts.most_common(1)[0]
    return top_val if top_count > 1 else np.nan

llm_raters = ['gpt', 'llama', 'qwen']

for var, cols in variables.items():
    cols_to_use = [cols[r] for r in llm_raters if cols[r] in merged.columns]
    if len(cols_to_use) >= 2:
        merged[f'{var}_llm_majority'] = merged[cols_to_use].apply(
            lambda row: majority_vote(row.values), axis=1
        )
    else:
        merged[f'{var}_llm_majority'] = np.nan


# summary table — human vs llm agreement
# binary variables use cohen's kappa, nominal use krippendorff's alpha,
# for each individual llm and the llm majority vote

var_labels = {
    'crime_present': 'Crime Present',
    'violent_crime': 'Violent Crime',
    'crime_label':   'Crime Label',
    'perp_race':     'Perpetrator Race',
    'perp_gender':   'Perpetrator Gender',
    'victim_race':   'Victim Race',
    'victim_gender': 'Victim Gender',
}

table_rows = []
for var, cols in variables.items():
    row = {'Variable': var_labels[var]}
    for human in ['eleanor', 'sarah']:
        if cols[human] not in merged.columns:
            continue
        for llm_name in llm_raters:
            if cols[llm_name] not in merged.columns:
                continue
            if var in binary_vars:
                val, n = cohens_kappa(merged[cols[human]], merged[cols[llm_name]])
                row[f'{human.capitalize()} vs {llm_name.upper()}'] = f'κ={val} (n={n})'
            else:
                val = kripp_alpha(merged[[cols[human], cols[llm_name]]])
                n = merged[[cols[human], cols[llm_name]]].notna().all(axis=1).sum()
                row[f'{human.capitalize()} vs {llm_name.upper()}'] = f'α={val} (n={n})'
        # also compare each human to the llm majority vote
        maj_col = f'{var}_llm_majority'
        if var in binary_vars:
            val, n = cohens_kappa(merged[cols[human]], merged[maj_col])
            row[f'{human.capitalize()} vs LLM Majority'] = f'κ={val} (n={n})'
        else:
            val = kripp_alpha(merged[[cols[human], maj_col]])
            n = merged[[cols[human], maj_col]].notna().all(axis=1).sum()
            row[f'{human.capitalize()} vs LLM Majority'] = f'α={val} (n={n})'
    table_rows.append(row)

table_df = pd.DataFrame(table_rows)
pd.set_option('display.max_columns', None, 'display.width', 200)
print("\n Agreement Table: Each Human Rater vs Each LLM ")
print(table_df.to_string(index=False))


# flag crime label disagreements
# save articles where raters disagreed on the crime label

lc = variables['crime_label']
dis = merged[['art_num'] + [lc[r] for r in raters if lc[r] in merged.columns]].copy()
dis.columns = ['art_num'] + [r for r in raters if lc[r] in merged.columns]

# mark rows where all raters gave the same label (ignoring NaNs)
def all_raters_agree(row):
    unique_values = set()
    for v in row:
        if pd.notna(v):
            unique_values.add(v)
    return len(unique_values) <= 1

dis['all_agree'] = dis.drop(columns='art_num').apply(all_raters_agree, axis=1)
dis[~dis['all_agree']].to_csv('crime_label_disagreements.csv', index=False)

print(f"\n✓ Saved: crime_label_disagreements.csv")
